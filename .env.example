# Qwen Cloud (Alibaba Cloud Model Studio / DashScope) — OpenAI-compatible endpoint.
# Get a key + free hackathon credits at qwencloud.com.
QWEN_API_KEY=sk-your-dashscope-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.7-plus
QWEN_EMBED_MODEL=text-embedding-v4
MEMORY_DIR=./.memory
RECALL_TOKEN_BUDGET=1200
RECALL_TOP_K=8
DECAY_HALFLIFE_DAYS=14
SALIENCE_FLOOR=0.12

# --- Safety / consent / ethics (see docs/legal/ and docs/ETHICS_ONBOARDING.md) ---
# Point at your org's ethics file to layer mission/voice/boundaries on the system prompt.
# AEGIS_ETHICS_FILE=./ethics.yaml
# Skip the interactive first-run consent gate (CI / headless deploys where you've already
# accepted the Terms on the operator's behalf):
# AEGIS_ASSUME_CONSENT=1
# Tighten the input screen to also block adult-sexual requests (off by default to avoid
# over-refusing legitimate security/legal/research use; minor-safety is ALWAYS hard-blocked):
# AEGIS_STRICT_SCREEN=1
